# ─── SMTP (required in production) ──────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password

# ─── Sender identity ─────────────────────────────────────────────────────────
MAIL_FROM=noreply@claudygod.com
MAIL_FROM_NAME=ClaudyGod Ministries

# ─── Admin inboxes ───────────────────────────────────────────────────────────
ADMIN_EMAIL=info@claudygod.com

# ─── CORS (comma-separated origins for API routes) ───────────────────────────
ALLOWED_ORIGIN=https://claudygod.com

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://claudygod.com
NODE_ENV=production
