# ═══════════════════════════════════════════════════════════════════════════
# PRODUCTION ENVIRONMENT VARIABLES
# Copy this file to .env.local and update with your values
# DO NOT commit .env.local to version control
# ═══════════════════════════════════════════════════════════════════════════

# ─── Node.js Configuration (Required) ─────────────────────────────────────────
NODE_ENV=production

# ─── Application URLs (Required) ──────────────────────────────────────────────
# Your frontend domain (used for redirects, canonical URLs, etc.)
NEXT_PUBLIC_SITE_URL=https://claudygod.com

# Your backend API URL (used for API calls from the browser)
NEXT_PUBLIC_API_URL=https://api.claudygod.com

# ─── Paystack Payment Gateway (Required for payments) ────────────────────────
# Public key: Use your Paystack public key (can be exposed to frontend)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key

# Secret key: Use your Paystack secret key (SERVER-SIDE ONLY - never expose)
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
