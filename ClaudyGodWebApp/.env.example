# Backend API Configuration
API_BASE_URL=http://api:8080

# API Key Configuration (comma-separated list)
# Generate secure keys: openssl rand -hex 32
VALID_API_KEYS=key1_xxxxxxxxxxxxx,key2_xxxxxxxxxxxxx,key3_xxxxxxxxxxxxx

# Internal API Key (for server-to-server communication)
# Keep this secure and different from public API keys
INTERNAL_API_KEY=internal_key_xxxxxxxxxxxxxxxxxxxxx

# JWT Configuration
# Generate secret: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_key_here_xxxxxxxxxxxxxxxxxxxxx
JWT_EXPIRY=7d

# Next.js Environment
NODE_ENV=production

# Security Headers
NEXT_PUBLIC_SECURITY_HEADERS=true

# Rate Limiting (optional)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Content Security Policy
NEXT_PUBLIC_CSP_ENABLED=true

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://claudygod.org,https://www.claudygod.org

# Feature Flags
NEXT_PUBLIC_VIDEO_PROXY_ENABLED=true
NEXT_PUBLIC_API_KEY_REQUIRED=true

# Logging
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
